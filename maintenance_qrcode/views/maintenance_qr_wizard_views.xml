<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maintenance_qr_print_wizard_form" model="ir.ui.view">
        <field name="name">maintenance.qr.print.wizard.form</field>
        <field name="model">maintenance.qr.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Equipment QR Codes">
                <group>
                    <field name="equipment_ids" widget="many2many_tags" readonly="1"/>
                    <field name="size"/>
                    <field name="copies"/>
                </group>
                <footer>
                    <button name="action_print" string="Print" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_maintenance_qr_print_wizard" model="ir.actions.act_window">
        <field name="name">Print QR Code</field>
        <field name="res_model">maintenance.qr.print.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_maintenance_qr_print_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{
            'default_equipment_ids': [(6, 0, context.get('active_ids', []))],
        }</field>
    </record>

</odoo>
