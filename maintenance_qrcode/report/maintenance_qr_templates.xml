<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_maintenance_equipment_qr">
        <t t-call="web.html_container">
            <t t-set="label_size" t-value="(data or {}).get('size', 'a4_3x8')"/>
            <t t-set="copies" t-value="int((data or {}).get('copies', 1))"/>

            <t t-if="label_size == '50x30'">
                <t t-set="label_style" t-value="'width:56mm;height:30mm;'"/>
                <t t-set="qr_size" t-value="19"/>
                <t t-set="font_size" t-value="9"/>
            </t>
            <t t-elif="label_size == '70x50'">
                <t t-set="label_style" t-value="'width:74mm;height:50mm;'"/>
                <t t-set="qr_size" t-value="24"/>
                <t t-set="font_size" t-value="10"/>
            </t>
            <t t-else="">
                <t t-set="label_style" t-value="'width:68mm;height:33.9mm;'"/>
                <t t-set="qr_size" t-value="22"/>
                <t t-set="font_size" t-value="10"/>
            </t>

            <div class="page" style="padding: 0; margin: 0;">
                <style>
                    .sg3d_qr_grid {
                        display: flex;
                        flex-wrap: wrap;
                        gap: 2mm;
                    }
                    .sg3d_qr_label {
                        border: 1px solid #ddd;
                        box-sizing: border-box;
                        padding: 2mm;
                        display: flex;
                        align-items: flex-start;
                        gap: 2.2mm;
                        overflow: hidden;
                        page-break-inside: avoid;
                        border-radius: 2mm;
                        background: #fff;
                    }
                    .sg3d_qr_label img {
                        width: 22mm;
                        height: 22mm;
                        object-fit: contain;
                        flex: 0 0 auto;
                    }
                    .sg3d_qr_code_img img {
                        width: 22mm !important;
                        height: 22mm !important;
                        object-fit: contain;
                        display: block;
                    }
                    .sg3d_qr_meta {
                        font-family: "DejaVu Sans", "Noto Sans", "Arial Unicode MS", Arial, sans-serif;
                        font-size: 10px;
                        line-height: 1.25;
                        overflow: visible;
                        word-break: break-word;
                        flex: 1 1 auto;
                    }
                    .sg3d_qr_code {
                        font-weight: 700;
                        margin-bottom: 1.2mm;
                        color: #222;
                    }
                    .sg3d_qr_name {
                        font-weight: 600;
                        color: #111;
                    }
                    .sg3d_qr_category {
                        color: #444;
                    }
                </style>

                <div class="sg3d_qr_grid">
                    <t t-foreach="docs" t-as="equipment">
                        <t t-foreach="range(copies)" t-as="_copy">
                            <div class="sg3d_qr_label" t-att-style="label_style">
                                <div class="sg3d_qr_code_img">
                                    <div t-field="equipment.x_qr_payload"
                                         t-options="{'widget': 'barcode', 'symbology': 'QR', 'width': 220, 'height': 220, 'img_style': 'width:%smm;height:%smm;' % (qr_size, qr_size)}"/>
                                </div>
                                <div class="sg3d_qr_meta" t-att-style="'font-size:%spx;' % font_size">
                                    <div class="sg3d_qr_code" t-esc="equipment.x_equipment_code or equipment.serial_no or '-'"/>
                                    <div class="sg3d_qr_name" t-esc="equipment.name"/>
                                </div>
                            </div>
                        </t>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
